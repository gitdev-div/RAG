# ══════════════════════════════════════════════════════
# RAG Agent — .gitignore
# ══════════════════════════════════════════════════════

# ── Python environments ────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Python cache ───────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd

# ── IDE & OS ───────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Data & uploads (keep repo lightweight) ────────────
data/
files to test/
image_files/
query/
mnt/
*.pdf
*.docx
*.log

# ── Secrets — NEVER commit these ──────────────────────
.env
.flaskenv       # contains Flask secrets / ports
auth.json

# NOTE: api_keys.py and openrouter.py are SOURCE FILES,
# not secrets — they must be committed and are NOT listed here.
# The actual secret (the API key) lives in the OS keychain,
# never in any file.

# ── Build & distribution ───────────────────────────────
dist/
build/
*.egg-info/

# ── Testing ────────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
